datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum GroupRole {
  OWNER
  EDITOR
  VIEWER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model User {
  id                    String                  @id @default(cuid())
  email                 String                  @unique
  name                  String
  firstName             String?
  lastName              String?
  phone                 String?
  address               String?
  city                  String?
  zipCode               String?
  avatar                String?
  avatarUrl             String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  
  ownedGroups           TripGroup[]             @relation("GroupOwner")
  memberships           TripMember[]
  suggestions           DestinationSuggestion[]
  votes                 DestinationVote[]
  messages              DiscussionMessage[]
  expenses              Expense[]
  bookings              Booking[]
  reviews               Review[]
}

model TravelPackage {
  id           String    @id @default(cuid())
  slug         String    @unique
  title        String
  destination  String
  price        Float
  currency     String
  duration     String
  image        String?
  type         String
  description  String?
  rating       Float     @default(5.0)
  gallery      String[]  @default([])
  highlights   String[]  @default([])
  bookingCount Int       @default(0)
  viewCount    Int       @default(0)
  
  bookings     Booking[]
  reviews      Review[]
}

model TripGroup {
  id                     String                  @id @default(uuid())
  name                   String
  ownerId                String
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  owner                  User                    @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members                TripMember[]
  itineraries            SharedItinerary[]
  destinationSuggestions DestinationSuggestion[]
  discussions            DiscussionMessage[]
  bookings               SharedBooking[]
  expenses               Expense[]
  invitations            TripInvitation[]
}

model TripMember {
  id          String    @id @default(uuid())
  tripGroupId String
  userId      String
  role        GroupRole @default(VIEWER)

  tripGroup   TripGroup @relation(fields: [tripGroupId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripGroupId, userId])
}

model TripInvitation {
  id          String           @id @default(uuid())
  tripGroupId String
  email       String
  invitedBy   String
  status      InvitationStatus @default(PENDING)

  tripGroup   TripGroup        @relation(fields: [tripGroupId], references: [id], onDelete: Cascade)
  
  @@unique([tripGroupId, email])
}

model SharedItinerary {
  id          String    @id @default(uuid())
  tripGroupId String
  title       String
  description String?
  dayNumber   Int
  createdBy   String
  updatedBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tripGroup   TripGroup @relation(fields: [tripGroupId], references: [id], onDelete: Cascade)
}

model DestinationSuggestion {
  id              String            @id @default(uuid())
  tripGroupId     String
  destinationName String
  suggestedBy     String
  createdAt       DateTime          @default(now())

  tripGroup       TripGroup         @relation(fields: [tripGroupId], references: [id], onDelete: Cascade)
  suggestedByUser User              @relation(fields: [suggestedBy], references: [id], onDelete: Cascade)
  votes           DestinationVote[]
}

model DestinationVote {
  id           String                @id @default(uuid())
  suggestionId String
  userId       String

  suggestion   DestinationSuggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  user         User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([suggestionId, userId])
}

model DiscussionMessage {
  id          String    @id @default(uuid())
  tripGroupId String
  userId      String
  message     String
  createdAt   DateTime  @default(now())

  tripGroup   TripGroup @relation(fields: [tripGroupId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SharedBooking {
  id               String    @id @default(uuid())
  tripGroupId      String
  bookingReference String
  bookingType      String
  amount           Float
  status           String
  createdAt        DateTime  @default(now())

  tripGroup        TripGroup @relation(fields: [tripGroupId], references: [id], onDelete: Cascade)
}

model Expense {
  id          String    @id @default(uuid())
  tripGroupId String?
  title       String?
  amount      Float
  paidBy      String?
  
  userId      String?
  tripLabel   String?
  category    String?
  currency    String    @default("INR")
  amountINR   Float?
  note        String?

  createdAt   DateTime  @default(now())

  tripGroup   TripGroup? @relation(fields: [tripGroupId], references: [id], onDelete: Cascade)
  payer       User?      @relation(fields: [paidBy], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Booking {
  id              String   @id @default(cuid())
  userId          String
  packageId       String
  totalAmount     Float
  currency        String
  numTravelers    Int
  selectedVehicle String?
  status          String   @default("Pending")
  paymentId       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  package         TravelPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  
  flight          BookingFlight?
  hotel           BookingHotel?
  addons          BookingAddon[]
}

model BookingFlight {
  id            String    @id @default(cuid())
  bookingId     String    @unique
  airline       String
  flightNumber  String
  departureTime DateTime?
  arrivalTime   DateTime?
  price         Float
  
  booking       Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model BookingHotel {
  id        String    @id @default(cuid())
  bookingId String    @unique
  hotelName String
  checkIn   DateTime?
  checkOut  DateTime?
  roomType  String?
  price     Float

  booking   Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model BookingAddon {
  id        String  @id @default(cuid())
  bookingId String
  addonName String
  price     Float

  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model Review {
  id        String   @id @default(cuid())
  packageId String
  userId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  package   TravelPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
}
